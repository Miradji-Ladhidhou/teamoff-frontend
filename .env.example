# ─────────────────────────────────────────────────────────────
# TEAMOFF FRONTEND — Variables d'environnement requises
# Copier ce fichier en .env (dev) ou .env.production (prod).
# NE JAMAIS commiter les fichiers .env.
# ─────────────────────────────────────────────────────────────

# URL de l'API backend (sans slash final)
# Dev  : http://localhost:5500/api
# Prod : https://votre-backend.onrender.com/api
VITE_API_URL=http://localhost:5500/api

# Port du serveur de développement Vite (défaut : 3001)
VITE_DEV_PORT=3001

# Cible du proxy dev (backend local, défaut : http://localhost:5500)
VITE_API_PROXY_TARGET=http://localhost:5500
